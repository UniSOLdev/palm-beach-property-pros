# Supabase — copy to `.env.local` and fill with values from Project Settings → API.
# Never commit `.env.local` (it is gitignored; keep real secrets out of the repo).

# Project URL (safe to expose in the browser with the anon key only).
NEXT_PUBLIC_SUPABASE_URL=

# Must be the anon/public key only (JWT role `anon`). Do not put the service_role secret here —
# anything `NEXT_PUBLIC_*` is bundled for the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret. Must never be exposed client-side or prefixed with NEXT_PUBLIC_.
# Used by server components/actions for admin dashboard DB access when configured.
SUPABASE_SERVICE_ROLE_KEY=
